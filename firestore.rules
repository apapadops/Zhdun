rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'al.papadopoulos@kaizengaming.com' || 
         request.auth.token.email == 'm.chatzicharalampous@kaizengaming.com' ||
         request.auth.token.email == 'v.vlachakis@kaizengaming.com' ||
         request.auth.token.email == 'admin@kaizengaming.com') &&
        request.auth.token.email_verified == true;
    }

    match /zhdun_submissions/{caseId} {
      // Open access for all signed-in users temporarily to fix connectivity
      allow read, write: if isSignedIn();
    }

    match /test/connection {
      allow get: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
