rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'al.papadopoulos@kaizengaming.com' || 
         request.auth.token.email == 'm.chatzicharalampous@kaizengaming.com' ||
         request.auth.token.email == 'v.vlachakis@kaizengaming.com' ||
         request.auth.token.email == 'admin@kaizengaming.com') &&
        request.auth.token.email_verified == true;
    }

    // Explicitly allow connection check
    match /test/connection {
      allow get: if true;
    }

    match /unified_cases/{caseId} {
      // Allow all signed-in users to list and get cases for the shared pipeline/dashboard
      allow read: if isSignedIn();
      
      // Allow create if signed in
      allow create: if isSignedIn();
      
      // Update: Admin or Owner (if pending)
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && resource.data.status == 'pending')
      );

      allow delete: if isAdmin();
    }
  }
}
