rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'al.papadopoulos@kaizengaming.com' || 
         request.auth.token.email == 'm.chatzicharalampous@kaizengaming.com' ||
         request.auth.token.email == 'v.vlachakis@kaizengaming.com' ||
         request.auth.token.email == 'admin@kaizengaming.com') &&
        request.auth.token.email_verified == true;
    }

    match /zhdun_submissions/{caseId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.requestor_department is string &&
        request.resource.data.project_title is string;
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status));
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow get: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
