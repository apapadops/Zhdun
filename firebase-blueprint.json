{
  "entities": {
    "UnifiedCase": {
      "title": "Unified Intake Case",
      "description": "Represents a unified transformation or AI initiative",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "project_title": { "type": "string" },
        "case_type": { "type": "string" },
        "status": { "type": "string" },
        "tier": { "type": "string" },
        "requestor_email": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "project_title", "status"]
    }
  },
  "firestore": {
    "/unified_cases/{caseId}": {
      "schema": "UnifiedCase",
      "description": "Collection of all intake initiatives"
    }
  }
}
